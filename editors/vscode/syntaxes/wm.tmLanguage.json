{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "wm-mini",
  "scopeName": "source.wm-mini",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constructors"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.wm-mini",
          "match": "(?:--|//).*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.wm-mini",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.wm-mini",
          "match": "\\\\."
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(export)\\s+(let)\\s+(rec\\s+)?([a-z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.wm-mini"
            },
            "2": {
              "name": "keyword.declaration.let.wm-mini"
            },
            "3": {
              "name": "keyword.declaration.rec.wm-mini"
            },
            "4": {
              "name": "entity.name.function.wm-mini"
            }
          }
        },
        {
          "match": "\\b(let)\\s+(rec\\s+)?([a-z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.let.wm-mini"
            },
            "2": {
              "name": "keyword.declaration.rec.wm-mini"
            },
            "3": {
              "name": "entity.name.function.wm-mini"
            }
          }
        },
        {
          "match": "\\b(export)\\s+(type)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.export.wm-mini"
            },
            "2": {
              "name": "keyword.declaration.type.wm-mini"
            },
            "3": {
              "name": "entity.name.type.wm-mini"
            }
          }
        },
        {
          "match": "\\b(type)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.wm-mini"
            },
            "2": {
              "name": "entity.name.type.wm-mini"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.wm-mini",
          "match": "\\b(if|else|match|from|import|export|as)\\b"
        },
        {
          "name": "keyword.declaration.wm-mini",
          "match": "\\b(let|rec|and|type|record)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.wm-mini",
          "match": "\\b(Number|String|Bool|Void)\\b"
        },
        {
          "name": "entity.name.type.wm-mini",
          "match": "\\b[A-Z][A-Za-z0-9_]*(?=\\s*(<|\\.|\\b))"
        }
      ]
    },
    "constructors": {
      "patterns": [
        {
          "name": "entity.name.function.constructor.wm-mini",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b(?=\\s*\\()"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.wm-mini",
          "match": "\\b(true|false|void)\\b"
        },
        {
          "name": "constant.numeric.float.wm-mini",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.wm-mini",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.wm-mini",
          "match": "=>|="
        },
        {
          "name": "keyword.operator.type.wm-mini",
          "match": ":|\\|"
        },
        {
          "name": "keyword.operator.wm-mini",
          "match": "<=|>=|==|!=|\\+|-|\\*|/|%|<|>|!"
        }
      ]
    }
  }
}
